@model TestSPA.ViewModel.LoginVM
@{
    ViewData["Title"] = "Login";
}

<style>
    .login-shell {
        min-height: calc(100vh - 120px);
        display: grid;
        place-items: center;
        padding: 2rem 0;
    }

    .login-scene {
        width: 100%;
        max-width: 1100px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 28px;
        overflow: hidden;
        background:
            radial-gradient(circle at top left, rgba(255, 184, 77, 0.18), transparent 30%),
            radial-gradient(circle at bottom right, rgba(94, 58, 238, 0.22), transparent 28%),
            linear-gradient(135deg, #0b0f19 0%, #121826 55%, #1a2235 100%);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45);
    }

    .login-panel {
        backdrop-filter: blur(12px);
        background: rgba(9, 12, 20, 0.78);
    }

    .login-copy {
        color: #eef2ff;
        padding: 3.5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 620px;
    }

    .login-kicker {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        width: fit-content;
        padding: 0.45rem 0.85rem;
        border-radius: 999px;
        background: rgba(255, 184, 77, 0.12);
        border: 1px solid rgba(255, 184, 77, 0.2);
        color: #ffd48f;
        font-size: 0.85rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 1.25rem;
    }

    .login-title {
        font-size: clamp(2.2rem, 5vw, 4rem);
        line-height: 1.02;
        font-weight: 700;
        letter-spacing: -0.04em;
        margin-bottom: 1rem;
    }

    .login-text {
        max-width: 28rem;
        color: rgba(226, 232, 240, 0.82);
        font-size: 1rem;
        line-height: 1.7;
        margin-bottom: 0;
    }

    .login-card {
        padding: 3rem;
        min-height: 620px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-form-wrap {
        width: 100%;
        max-width: 420px;
        padding: 2rem;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .login-form-wrap h1 {
        color: #f8fafc;
        font-size: 2rem;
        letter-spacing: -0.03em;
        margin-bottom: 0.5rem;
    }

    .login-form-wrap p {
        color: rgba(226, 232, 240, 0.72);
        margin-bottom: 1.75rem;
    }

    .login-label {
        color: #dbe4ff;
        font-size: 0.92rem;
        margin-bottom: 0.5rem;
    }

    .login-input {
        height: 52px;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(5, 8, 16, 0.8);
        color: #f8fafc;
        padding: 0.9rem 1rem;
    }

    .login-input:focus {
        background: rgba(5, 8, 16, 0.92);
        color: #fff;
        border-color: rgba(255, 184, 77, 0.65);
        box-shadow: 0 0 0 0.2rem rgba(255, 184, 77, 0.15);
    }

    .login-input::placeholder {
        color: rgba(148, 163, 184, 0.7);
    }

    .login-button {
        height: 54px;
        border: 0;
        border-radius: 14px;
        background: linear-gradient(135deg, #ffb84d 0%, #ff8a3d 100%);
        color: #111827;
        font-weight: 700;
        letter-spacing: 0.02em;
        transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
        box-shadow: 0 18px 35px rgba(255, 138, 61, 0.25);
    }

    .login-button:hover,
    .login-button:focus {
        color: #111827;
        transform: translateY(-1px);
        filter: brightness(1.03);
    }

    .login-error {
        border-radius: 14px;
        border: 1px solid rgba(248, 113, 113, 0.28);
        background: rgba(127, 29, 29, 0.3);
        color: #fecaca;
        padding: 0.9rem 1rem;
        margin-bottom: 1rem;
    }

    .field-validation-error {
        display: inline-block;
        margin-top: 0.45rem;
        color: #fda4af;
        font-size: 0.85rem;
    }

    @@media (max-width: 991.98px) {
        .login-copy,
        .login-card {
            min-height: auto;
            padding: 2rem;
        }

        .login-form-wrap {
            padding: 1.5rem;
        }
    }
</style>

<div class="login-shell">
    <div class="login-scene">
        <div class="row g-0">
            <div class="col-lg-6">
                <div class="login-copy">
                    <div class="login-kicker">Vogue Jewellers</div>
                    <h2 class="login-title">OG Verification</h2>
                </div>
            </div>
            <div class="col-lg-6 login-panel">
                <div class="login-card">
                    <div class="login-form-wrap">
                        <h1>Welcome back</h1>
                        <p>Use your credentials to access the workspace.</p>

                        <form asp-action="Login" method="post">
                            @Html.AntiForgeryToken()
                            <input asp-for="ReturnUrl" type="hidden" />

                            <div asp-validation-summary="ModelOnly" class="login-error" role="alert"></div>

                            <div class="mb-3">
                                <label asp-for="Username" class="form-label login-label"></label>
                                <input asp-for="Username" class="form-control login-input" autocomplete="username" placeholder="Enter username" />
                                <span asp-validation-for="Username"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Password" class="form-label login-label"></label>
                                <input asp-for="Password" class="form-control login-input" autocomplete="current-password" placeholder="Enter password" />
                                <span asp-validation-for="Password"></span>
                            </div>

                            <button type="submit" class="btn login-button w-100">Sign In</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
