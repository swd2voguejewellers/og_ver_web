@{
    ViewBag.Title = "OG Verification";
    var isManager = string.Equals(User.FindFirst("user_type")?.Value, "MGR", StringComparison.OrdinalIgnoreCase);
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<style>
    :root {
        --og-bg: #0c111b;
        --og-panel: rgba(14, 20, 32, 0.88);
        --og-panel-strong: #121a29;
        --og-panel-soft: #182335;
        --og-border: rgba(255, 255, 255, 0.08);
        --og-text: #edf2ff;
        --og-muted: #96a3bd;
        --og-accent: #f7b84b;
        --og-accent-deep: #ff8c42;
        --og-success: #31c48d;
        --og-danger: #ff6b6b;
        --og-info: #7dd3fc;
        --og-shadow: 0 22px 50px rgba(0, 0, 0, 0.32);
    }

    body {
        background:
            radial-gradient(circle at top left, rgba(247, 184, 75, 0.10), transparent 26%),
            radial-gradient(circle at bottom right, rgba(73, 132, 255, 0.14), transparent 30%),
            linear-gradient(180deg, #0a0f18 0%, #101726 42%, #0c111b 100%);
        color: var(--og-text);
    }

    .og-shell {
        max-width: 1280px;
        margin: 0 auto;
        padding: 1.25rem 0 2rem;
    }

    .og-hero,
    .og-panel,
    .og-stats-card,
    .og-rates-card {
        border: 1px solid var(--og-border);
        border-radius: 24px;
        background: var(--og-panel);
        box-shadow: var(--og-shadow);
        backdrop-filter: blur(14px);
    }

    .og-hero {
        padding: 1.5rem;
        margin-bottom: 1rem;
        background:
            radial-gradient(circle at top right, rgba(247, 184, 75, 0.12), transparent 25%),
            linear-gradient(135deg, rgba(15, 22, 35, 0.96), rgba(19, 27, 42, 0.92));
    }

    .og-kicker {
        display: inline-flex;
        width: fit-content;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #ffd89d;
        background: rgba(247, 184, 75, 0.12);
        border: 1px solid rgba(247, 184, 75, 0.22);
        margin-bottom: 0.85rem;
    }

    .og-title {
        font-size: clamp(2rem, 4vw, 3.1rem);
        line-height: 1;
        letter-spacing: -0.04em;
        font-weight: 700;
        margin-bottom: 0.6rem;
    }

    .og-subtitle {
        max-width: 44rem;
        color: var(--og-muted);
        margin-bottom: 1.25rem;
        line-height: 1.65;
    }

    .og-inline-note {
        color: var(--og-muted);
        font-size: 0.92rem;
    }

    .og-panel {
        padding: 1.25rem;
        margin-bottom: 1rem;
    }

    .og-section-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .og-section-title {
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: 0.2rem;
    }

    .og-section-copy {
        color: var(--og-muted);
        font-size: 0.92rem;
        margin-bottom: 0;
    }

    .og-form-label {
        color: #d7e2f8;
        font-size: 0.88rem;
        font-weight: 600;
        margin-bottom: 0.45rem;
    }

    .og-input,
    .og-select {
        min-height: 52px;
        border-radius: 16px;
        background: rgba(8, 13, 22, 0.82);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: var(--og-text);
        box-shadow: none;
    }

    .og-input:focus,
    .og-select:focus {
        background: rgba(8, 13, 22, 0.96);
        color: #fff;
        border-color: rgba(247, 184, 75, 0.52);
        box-shadow: 0 0 0 0.2rem rgba(247, 184, 75, 0.14);
    }

    .og-searchselect {
        position: relative;
    }

    .og-searchselect-dropdown {
        position: relative;
        z-index: 40;
        margin-top: 6px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.10);
        background: rgba(8, 13, 22, 0.98);
        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.40);
        max-height: 260px;
        overflow: auto;
        padding: 6px;
        display: none;
    }

    .og-searchselect-item {
        padding: 10px 12px;
        border-radius: 12px;
        color: var(--og-text);
        cursor: pointer;
        user-select: none;
    }

    .og-searchselect-item:hover,
    .og-searchselect-item[aria-selected="true"] {
        background: rgba(247, 184, 75, 0.14);
        border: 1px solid rgba(247, 184, 75, 0.20);
    }

    .og-searchselect-muted {
        color: var(--og-muted);
        padding: 10px 12px;
        font-size: 0.9rem;
    }

    .og-readonly {
        color: #111827;
        font-weight: 700;
        background: linear-gradient(135deg, rgba(247, 184, 75, 0.14), rgba(255, 140, 66, 0.08));
    }

    .og-btn {
        min-height: 52px;
        border-radius: 16px;
        font-weight: 700;
        border: 0;
    }

    .og-btn-load {
        background: linear-gradient(135deg, #f7b84b, #ff8c42);
        color: #10131b;
        box-shadow: 0 16px 30px rgba(255, 140, 66, 0.22);
    }

    .og-btn-add {
        background: linear-gradient(135deg, #36d399, #10b981);
        color: #04120e;
        box-shadow: 0 16px 30px rgba(16, 185, 129, 0.22);
    }

    .og-btn-save {
        background: linear-gradient(135deg, #60a5fa, #2563eb);
        color: #f8fbff;
        box-shadow: 0 16px 30px rgba(37, 99, 235, 0.24);
    }

    .og-btn-approve {
        background: linear-gradient(135deg, #f7b84b, #f97316);
        color: #1a1204;
        box-shadow: 0 16px 30px rgba(249, 115, 22, 0.24);
    }

    .og-btn-delete {
        border-radius: 12px;
        border: 1px solid rgba(255, 107, 107, 0.28);
        background: rgba(255, 107, 107, 0.12);
        color: #ffc0c0;
    }

    .og-btn:hover {
        filter: brightness(1.03);
    }

    .og-disabled {
        opacity: 0.55;
        pointer-events: none;
    }

    .og-load-grid {
        align-items: end;
    }

    .og-toolbar {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        align-items: center;
    }

    .og-summary-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .og-stat {
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: linear-gradient(180deg, rgba(23, 32, 48, 0.9), rgba(15, 21, 32, 0.92));
        padding: 1rem 1.1rem;
    }

    .og-stat-label {
        color: var(--og-muted);
        font-size: 0.84rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.45rem;
    }

    .og-stat-value {
        font-size: clamp(1.45rem, 2.2vw, 2rem);
        font-weight: 700;
        color: var(--og-accent);
        letter-spacing: -0.03em;
    }

    .og-table-wrap {
        border-radius: 22px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(9, 14, 23, 0.9);
    }

    .og-table {
        margin-bottom: 0;
        color: var(--og-text);
        --bs-table-bg: transparent;
        --bs-table-color: var(--og-text);
        --bs-table-border-color: rgba(255, 255, 255, 0.06);
        --bs-table-striped-bg: rgba(255, 255, 255, 0.02);
        --bs-table-hover-bg: rgba(96, 165, 250, 0.08);
        min-width: 760px;
    }

    .og-table thead th {
        background: rgba(19, 28, 43, 0.96);
        color: #dbe7fb;
        font-size: 0.84rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding: 1rem 0.85rem;
        white-space: nowrap;
    }

    .og-table td {
        padding: 0.95rem 0.85rem;
        vertical-align: middle;
        color: #ffffff;
    }

    .og-empty {
        padding: 3rem 1.25rem;
        text-align: center;
        color: var(--og-muted);
    }

    .og-empty strong {
        display: block;
        color: #f7fbff;
        margin-bottom: 0.4rem;
        font-size: 1.05rem;
    }

    .og-rates-card {
        padding: 1rem;
    }

    .og-rates-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 0.75rem;
    }

    .og-rate-pill {
        border-radius: 18px;
        padding: 0.95rem 0.85rem;
        background: linear-gradient(180deg, rgba(23, 32, 48, 0.95), rgba(13, 19, 29, 0.96));
        border: 1px solid rgba(255, 255, 255, 0.06);
        text-align: center;
    }

    .og-rate-label {
        font-size: 0.78rem;
        color: var(--og-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.35rem;
    }

    .og-rate-value {
        font-size: 1.15rem;
        font-weight: 700;
        color: #fff5da;
    }

    .og-sticky-actions {
        position: sticky;
        bottom: 1rem;
        z-index: 5;
        margin-top: 1rem;
    }

    .og-action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 0.9rem 1rem;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(10, 15, 24, 0.88);
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.28);
        backdrop-filter: blur(12px);
    }

    .og-action-meta {
        color: var(--og-muted);
        font-size: 0.92rem;
    }

    @@media (max-width: 991.98px) {
        .og-hero,
        .og-panel {
            padding: 1rem;
            border-radius: 20px;
        }

        .og-summary-grid {
            grid-template-columns: 1fr;
        }

        .og-rates-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 767.98px) {
        .og-shell {
            padding-top: 0.5rem;
        }

        .og-rates-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .og-action-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .og-toolbar,
        .og-section-head {
            align-items: stretch;
        }
    }
</style>

<div class="container-fluid px-0">
    <div class="og-shell">
        <section class="og-hero">
            <div class="row align-items-center g-3">
                <div class="col-lg-8">
                    <div class="og-kicker">Tablet Ready Workspace</div>
                    <h1 class="og-title">OG Verification</h1>
                </div>
            </div>
        </section>

        <section class="og-panel">
            <div class="og-section-head">
                <div>
                    <div class="og-section-title">Load Existing Verification</div>
                </div>
            </div>

            <div class="row g-3 og-load-grid">
                <div class="col-12 col-md-6 col-lg-3">
                    <label class="form-label og-form-label" for="ogNo">OG Verify No</label>
                    <input id="ogNo" type="number" class="form-control og-input" placeholder="Enter verification number" />
                </div>
                <div class="col-12 col-md-6 col-lg-2">
                    <button id="btnLoad" class="btn og-btn og-btn-load w-100">Load Record</button>
                </div>
                <div class="col-12 col-md-6 col-lg-2">
                    <button id="btnPrint" class="btn og-btn btn-outline-light w-100">Print</button>
                </div>
            </div>
        </section>

        <section class="og-panel">
            <div class="og-section-head">
                <div>
                    <div class="og-section-title">Item Composer</div>
                </div>
                <div class="og-toolbar">
                    <button id="btnAdd" class="btn og-btn og-btn-add px-4">Add Item</button>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-12 col-md-6 col-xl-4">
                    <label class="form-label og-form-label" for="item">Item</label>
                    <select id="item" class="form-select og-select">
                        <option value="">Select</option>
                        <option value="Bangle">Bangle</option>
                        <option value="Rings-Wedding (G)">Rings-Wedding (G)</option>
                        <option value="Rings-Wedding (L)">Rings-Wedding (L)</option>
                        <option value="Rings-Standard">Rings-Standard</option>
                        <option value="Necklace">Necklace</option>
                        <option value="Chain">Chain</option>
                        <option value="Bracelet (G)">Bracelet (G)</option>
                        <option value="Bracelet (L)">Bracelet (L)</option>
                        <option value="Pendant">Pendant</option>
                        <option value="Earstud">Earstud</option>
                        <option value="B/B">B/B</option>
                        <option value="S-Lock">S-Lock</option>
                        <option value="Spring Lock">Spring Lock</option>
                        <option value="Coin">Coin</option>
                        <option value="Biscuit">Biscuit</option>
                        <option value="Slab">Slab</option>
                        <option value="Thalishment">Thalishment</option>
                        <option value="Panchayuda">Panchayuda</option>
                        <option value="Gold Pieces">Gold Pieces</option>
                        <option value="Other Miscellaneous">Other Miscellaneous</option>
                    </select>
                </div>

                <div class="col-6 col-md-3 col-xl-2">
                    <label class="form-label og-form-label" for="carat">Carat</label>
                    <input id="carat" type="number" step="0.1" min="0" max="24" class="form-control og-input" value="22" />
                </div>

                <div class="col-6 col-md-3 col-xl-2">
                    <label class="form-label og-form-label" for="weight">Weight</label>
                    <input id="weight" type="number" class="form-control og-input" placeholder="0.00" />
                </div>

                <div class="col-6 col-md-6 col-xl-2">
                    <label class="form-label og-form-label" for="actVal">Actual Value</label>
                    <input id="actVal" class="form-control og-input og-readonly" readonly />
                </div>

                <div class="col-6 col-md-6 col-xl-2">
                    <label class="form-label og-form-label" for="givVal">Given Value</label>
                    <input id="givVal" type="number" class="form-control og-input" placeholder="0.00" />
                </div>

                <div class="col-12 col-xl-4">
                    <label class="form-label og-form-label" for="reason">Reason</label>
                    <select id="reason" class="form-select og-select">
                        <option value="">Select</option>
                        <option>Stones available</option>
                        <option>Stocking item</option>
                        <option>Vogue item</option>
                        <option>Higher karatage</option>
                        <option>Special price given</option>
                        <option>Studded with diamonds</option>
                        <option>Apperance of the item</option>
                        <option>Other</option>
                    </select>
                </div>
            </div>
        </section>

        <section class="og-panel">
            <div class="og-section-head">
                <div>
                    <div class="og-section-title">Verification Items</div>
                </div>
            </div>

            <div class="og-table-wrap">
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle og-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Item</th>
                                <th>Carat</th>
                                <th>Weight</th>
                                <th>Act Value</th>
                                <th>Given Value</th>
                                <th>Reason</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="grid"></tbody>
                    </table>
                </div>
            </div>
        </section>

        <div class="og-summary-grid">
            <div class="og-stat">
                <div class="og-stat-label">Total Weight</div>
                <div class="og-stat-value" id="totWgt">0.00</div>
            </div>
            <div class="og-stat">
                <div class="og-stat-label">Total Value</div>
                <div class="og-stat-value" id="totVal">0.00</div>
            </div>
            <div class="og-stat">
                <div class="og-stat-label">Average Rate</div>
                <div class="og-stat-value" id="avgRate">0.00</div>
            </div>
        </div>

        <section class="og-panel">
            <div class="og-section-head">
                <div>
                    <div class="og-section-title">Approval Details</div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label og-form-label" for="Sales">Sales Person</label>
                    <select id="Sales" class="form-select og-select"></select>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label og-form-label" for="assSales">Ass Sales Person</label>
                    <select id="assSales" class="form-select og-select"></select>
                </div>
                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label og-form-label" for="priceBy">Price Given By</label>
                    <select id="priceBy" class="form-select og-select"></select>
                </div>
                <div class="col-12 col-md-6 col-xl-3 d-none" id="avgReasonDiv">
                    <label class="form-label og-form-label" for="avgReason">Avg Gold Rate Reason</label>
                    <input id="avgReason" class="form-control og-input" placeholder="Add reason when average exceeds the 22KT rate" />
                </div>
            </div>
        </section>

        <section class="og-rates-card" id="ratesDiv">
            <div class="og-section-head mb-3">
                <div>
                    <div class="og-section-title">Current OG Rates</div>
                </div>
            </div>

            <div class="og-rates-grid">
                <div class="og-rate-pill">
                    <div class="og-rate-label">24 KT</div>
                    <div class="og-rate-value" id="r24">0.00</div>
                </div>
                <div class="og-rate-pill">
                    <div class="og-rate-label">OG 22 KT</div>
                    <div class="og-rate-value" id="r22">0.00</div>
                </div>
                <div class="og-rate-pill">
                    <div class="og-rate-label">OG 21 KT</div>
                    <div class="og-rate-value" id="r21">0.00</div>
                </div>
                <div class="og-rate-pill">
                    <div class="og-rate-label">OG 20 KT</div>
                    <div class="og-rate-value" id="r20">0.00</div>
                </div>
                <div class="og-rate-pill">
                    <div class="og-rate-label">OG 19 KT</div>
                    <div class="og-rate-value" id="r19">0.00</div>
                </div>
                <div class="og-rate-pill">
                    <div class="og-rate-label">OG 18 KT</div>
                    <div class="og-rate-value" id="r18">0.00</div>
                </div>
            </div>
        </section>

        <div class="og-sticky-actions">
            <div class="og-action-bar">
                <div class="og-action-meta">
                    Review the items and approval fields, then save the verification record.
                </div>
                <div class="og-toolbar">
                    <button id="btnSave" class="btn og-btn og-btn-save px-4">Save Verification</button>
                    @if (isManager)
                    {
                        <button id="btnApprove" class="btn og-btn og-btn-approve px-4">Approve Verification</button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const appBase = '@Url.Content("~/")'.replace(/\/$/, '');
    const appUrl = (path) => `${appBase}${path}`;
    const isManager = @isManager.ToString().ToLowerInvariant();
    let list = [];
    let currentOGNo = 0;
    let rates = null;
    let isApprovedRecord = false;

    $(document).ready(function () {
        setApprovalMode(false);

        $(document).ajaxError(function (event, xhr) {
            if (xhr.status === 401) {
                let returnUrl = window.location.pathname + window.location.search;
                window.location.href = appUrl('/Account/Login') + '?returnUrl=' + encodeURIComponent(returnUrl);
            }
        });

        $("#btnAdd").click(function () {
            addRow();
        });

        $("#btnSave").click(function () {
            submitData(false);
        });

        $("#btnApprove").click(function () {
            submitData(true);
        });

        $('#weight, #carat').on('input', function () {
            calculateActVal();
        });

        $("#btnLoad").click(function () {

            let ogNo = parseInt($("#ogNo").val());

            if (!ogNo || ogNo <= 0) {
                alert("Enter valid OG No");
                return;
            }

            $.ajax({
                url: appUrl('/Home/GetOGDetails'),
                type: 'GET',
                data: { ogVerifyNo: ogNo },
                success: function (res) {
                    console.log(res);

                    list = [];
                    let details = res.details || [];
                    isApprovedRecord = !!res.isApproved;

                    // Check if staff info exists (take from first item if present)
                    let firstItem = details[0] || {};
                    let salesPerson = firstItem.salesPerson || "";
                    let assSales = firstItem.assSalesPerson || "";
                    let priceBy = firstItem.priceGivBy || "";
                    let avgReason = firstItem.avgGRReason || "";
                    let avgGoldRate = firstItem.avgGoldRate

                    // Ensure selected names exist as options (in case staff list is loaded later/different)
                    if (salesPerson && $("#Sales option").filter(function () { return $(this).val() === salesPerson; }).length === 0) {
                        $("#Sales").append(`<option value="${salesPerson}">${salesPerson}</option>`);
                    }
                    if (assSales && $("#assSales option").filter(function () { return $(this).val() === assSales; }).length === 0) {
                        $("#assSales").append(`<option value="${assSales}">${assSales}</option>`);
                    }
                    if (priceBy && $("#priceBy option").filter(function () { return $(this).val() === priceBy; }).length === 0) {
                        $("#priceBy").append(`<option value="${priceBy}">${priceBy}</option>`);
                    }

                    // Set dropdowns
                    $("#Sales").val(salesPerson).trigger("change");
                    $("#assSales").val(assSales).trigger("change");
                    $("#priceBy").val(priceBy).trigger("change");
                    $("#avgReason").val(avgReason);
                    const avgGoldRateValue = Number(avgGoldRate ?? 0);
                    $("#avgRate").text(avgGoldRateValue.toFixed(2));

                    // Show avg reason field if value exists
                    if (avgReason) {
                        $("#avgReasonDiv").removeClass("d-none");
                    } else {
                        $("#avgReasonDiv").addClass("d-none");
                    }

                    // Fill table rows
                    $.each(details, function (i, x) {
                            list.push({
                                Id: x.id, 

                                Num: x.num,
                                ItemDesc: x.itemDesc,
                                Caratage: x.caratage,
                                OGWgt: x.ogWgt,
                                OGActVal: x.ogActVal,
                                OGGivVal: x.ogGivVal,
                                ReleaseReason: x.releaseReason,

                                SalesPerson: x.salesPerson,
                                AssSalesPerson: x.assSalesPerson,
                                PriceGivBy: x.priceGivBy,
                                AvgGRReason: x.avgGRReason,

                                KT_24: x.kt_24,
                                OG_22_KT: x.og_22_KT,
                                OG_21_KT: x.og_21_KT,
                                OG_20_KT: x.og_20_KT,
                                OG_19_KT: x.og_19_KT,
                                OG_18_KT: x.og_18_KT
                            });
                    });

                    currentOGNo = ogNo;

                    renderTable();
                    calculateTotals();
                    setApprovalMode(isApprovedRecord);

                },
                error: function () {
                    alert("No data found!");
                }
            });

        });

        $("#btnPrint").click(function () {
            let ogNo = parseInt($("#ogNo").val());

            if (!ogNo || ogNo <= 0) {
                alert("Enter valid OG No");
                return;
            }

            window.open(appUrl('/Home/PrintOG') + '?ogVerifyNo=' + encodeURIComponent(ogNo), '_blank', 'noopener,noreferrer');
        });

        loadStaff();
        loadRates();

    });

    function calculateActVal() {
        let weight = parseFloat($('#weight').val());
        let carat = parseFloat($('#carat').val());

        //  If missing ? clear ActVal
        if (!weight || !carat) {
            $('#actVal').val('');
            return;
        }

        $.ajax({
            url: appUrl('/Home/CalculateActVal'),
            type: 'GET',
            data: { weight: weight, carat: carat },
            success: function (res) {
                if (res === null) {
                    $('#actVal').val('');
                } else {
                    $('#actVal').val(res.toFixed(2));
                }
            },
            error: function () {
                $('#actVal').val('');
            }
        });
    }

    function addRow() {

        let item = $("#item").val();
        let carat = parseFloat($("#carat").val()) || 0;
        let weight = parseFloat($("#weight").val()) || 0;
        let actVal = parseFloat($("#actVal").val()) || 0;
        let givVal = parseFloat($("#givVal").val()) || 0;
        let reason = $("#reason").val();

        if (!item || !carat || carat <= 0 || weight <= 0) {
            alert("Fill required fields!");
            return;
        }

        // ? NEW VALIDATION
        let upperLimit = actVal + 1000;
        let lowerLimit = actVal - 2000;

        if ((givVal > upperLimit || givVal < lowerLimit) && !reason) {
            alert("Release Reason required");
            $("#reason").focus();
            return;
        }

        let obj = {
            Id: 0, // ? NEW ROW

            ItemDesc: item,
            Caratage: `${parseFloat(carat) || 0} KT`,
            OGWgt: weight,
            OGActVal: actVal,
            OGGivVal: givVal,
            ReleaseReason: reason
        };

        list.push(obj);

        renderTable();
        calculateTotals();
        clearInputs();
    }

     function renderTable() {

        if (list.length === 0) {
            $("#grid").html(`
                <tr>
                    <td colspan="8" class="og-empty">
                        <strong>No items added yet</strong>
                        Start with the composer above or load an existing verification number.
                    </td>
                </tr>`);
            return;
        }

        let html = "";

        $.each(list, function (i, x) {
            html += `<tr>
                    <td>${i + 1}</td>

                    <!-- HIDDEN ID -->
                    <td style="display:none;">
                        <input type="hidden" value="${x.Id || 0}" />
                    </td>

                    <!-- READ ONLY FIELDS -->
                    <td>${x.ItemDesc}</td>
                    <td>${x.Caratage}</td>
                    <td>${x.OGWgt}</td>
                    <td>${x.OGActVal}</td>

                    <!-- ONLY EDITABLE FIELDS -->
                    <td>
                        <input type="number" value="${x.OGGivVal || 0}"
                               onchange="updateField(${i}, 'OGGivVal', this.value)"
                               class="form-control og-input"/>
                    </td>
                    <td>
                        <input value="${x.ReleaseReason || ''}"
                               onchange="updateField(${i}, 'ReleaseReason', this.value)"
                               class="form-control og-input"/>
                    </td>

                    <td>
                        <button class="btn og-btn-delete btn-sm" onclick="removeRow(${i})">Delete</button>
                    </td>
                </tr>`;
        });

        $("#grid").html(html);
    }

    function removeRow(index) {
        if (isApprovedRecord) {
            return;
        }

        list.splice(index, 1);
        renderTable();
        calculateTotals();
    }

    function calculateTotals() {

        let totWgt = 0;
        let totVal = 0;

        $.each(list, function (i, x) {
            totWgt += x.OGWgt;
            totVal += x.OGGivVal;
        });

        $("#totWgt").text(totWgt.toFixed(2));
        $("#totVal").text(totVal.toFixed(2));

        if (totWgt > 0) {
            $("#avgRate").text(((totVal / totWgt) * 8).toFixed(2));
        }
    }

    function clearInputs() {
        $("#item, #weight, #actVal, #givVal, #reason").val('');
        $("#carat").val('22');
    }

    function submitData(isApprove) {
            if (isApprovedRecord) {
                alert("Approved records cannot be edited.");
                return;
            }

            // if (list.length === 0) {
            //     alert("No data to save!");
            //     return;
            // }

            let salesPerson = $("#Sales").val();   // ? FIXED ID
            let assSales = $("#assSales").val();
            let priceBy = $("#priceBy").val();
            let avgReason = $("#avgReason").val();

            let totWgt = parseFloat($("#totWgt").text()) || 0;
            let totVal = parseFloat($("#totVal").text()) || 0;

            let avgRate = 0;

            if (totWgt > 0) {
                avgRate = (totVal / totWgt) * 8;
            }

            // ? BASIC VALIDATION
            if (!salesPerson) {
                alert("Select Sales Person");
                $("#Sales").focus();
                return;
            }

            if (!assSales) {
                alert("Select Assistant Sales");
                $("#assSales").focus();
                return;
            }

            if (!priceBy) {
                alert("Select Price Given By");
                $("#priceBy").focus();
                return;
            }

            // ? CHECK AVG > 22KT RATE
            let rate22 = rates?.oG_22_KT || 0;

            if (avgRate > rate22) {

                // SHOW FIELD
                $("#avgReasonDiv").removeClass("d-none");

                if (!avgReason) {
                    alert("Avg Rate is higher than 22KT rate. Please enter reason!");
                    $("#avgReason").focus();
                    return;
                }
            } else {
                // HIDE FIELD
                $("#avgReasonDiv").addClass("d-none");
            }

            

            // ? Attach to each item
            let updatedList = list.map((x, index) => ({
                    ...x,

                    Id: x.Id || 0,     // ? IMPORTANT
                    Num: index + 1,

                    SalesPerson: salesPerson,
                    AssSalesPerson: assSales,
                    PriceGivBy: priceBy,
                    AvgGRReason: avgReason,
                    AvgGoldRate : avgRate,

                    KT_24: rates.kT_24,
                    OG_22_KT: rates.oG_22_KT,
                    OG_21_KT: rates.oG_21_KT,
                    OG_20_KT: rates.oG_20_KT,
                    OG_19_KT: rates.oG_19_KT,
                    OG_18_KT: rates.oG_18_KT
                }));

            let payload = {
                ogVerifyNo: currentOGNo === 0 ? null : currentOGNo,
                details: updatedList   // ? IMPORTANT FIX
            };
            
            for (let i = 0; i < list.length; i++) {

                let x = list[i];

                let upperLimit = x.OGActVal + 1000;
                let lowerLimit = x.OGActVal - 2000;

                if ((x.OGGivVal > upperLimit || x.OGGivVal < lowerLimit) && !x.ReleaseReason) {
                    alert(`Row ${i + 1}: Release Reason required`);
                    return;
                }
            }

            $.ajax({
                url: appUrl(isApprove ? '/Home/ApproveOG' : '/Home/SaveOrUpdateOG'),
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                success: function (res) {

                        if (res.success) {
                        alert((isApprove ? "Approved! OG No: " : "Saved! OG No: ") + res.message);

                        currentOGNo = res.message;
                        $("#ogNo").val(res.message);

                        if (isApprove) {
                            isApprovedRecord = true;
                            setApprovalMode(true);
                            renderTable();
                        } else {
                            isApprovedRecord = false;
                            setApprovalMode(false);
                            list = [];
                            renderTable();
                        }

                        // Clear inputs
                        $("#item").val('');
                        $("#carat").val(22); // reset default
                        $("#weight").val('');
                        $("#actVal").val('');
                        $("#givVal").val('');
                        $("#reason").val('');

                        // Clear totals
                        $("#totWgt").text('0.00');
                        $("#totVal").text('0.00');
                        $("#avgRate").text('0.00');

                        // Hide avg reason
                        $("#avgReason").val('');
                        $("#avgReasonDiv").addClass("d-none");

                        // OPTIONAL: reset dropdowns
                        $("#Sales").val('');
                        $("#assSales").val('');
                        $("#priceBy").val('');
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 403) {
                        const message = xhr.responseJSON?.message || "Only MGR users can approve records.";
                        alert(message);
                        return;
                    }

                    if (xhr.status === 409) {
                        alert("Approved records cannot be edited.");
                        isApprovedRecord = true;
                        setApprovalMode(true);
                        renderTable();
                        return;
                    }

                    alert(isApprove ? "Error approving!" : "Error saving!");
                }
            });
     }

    function updateField(index, field, value) {

        if (field === "OGWgt" || field === "OGGivVal") {
            value = parseFloat(value) || 0;
        }

        list[index][field] = value;

        calculateTotals();
    }

    function setApprovalMode(locked) {
        $("#btnAdd").prop("disabled", locked);
        $("#btnSave").prop("disabled", locked);
        $("#btnApprove").prop("disabled", locked);
    }

    function loadStaff() {

        $.get(appUrl('/Home/GetStaff'), function (res) {

            // preserve selected values (e.g., when loading an existing OG record)
            const prevSales = $("#Sales").val();
            const prevAssSales = $("#assSales").val();
            const prevPriceBy = $("#priceBy").val();

            $("#Sales, #assSales, #priceBy").empty();

            $("#Sales").append(`<option value="">Select</option>`);
            $("#assSales").append(`<option value="">Select</option>`);
            $("#priceBy").append(`<option value="">Select</option>`);

            $.each(res, function (i, name) {
                $("#Sales").append(`<option value="${name}">${name}</option>`);
                $("#assSales").append(`<option value="${name}">${name}</option>`);
                $("#priceBy").append(`<option value="${name}">${name}</option>`);
            });

            // restore (if the value still exists in the new option list)
            if (prevSales) $("#Sales").val(prevSales).trigger("change");
            if (prevAssSales) $("#assSales").val(prevAssSales).trigger("change");
            if (prevPriceBy) $("#priceBy").val(prevPriceBy).trigger("change");

            enhanceSearchableSelect("#Sales");
            enhanceSearchableSelect("#assSales");
            enhanceSearchableSelect("#priceBy");

        });
    }

    function loadRates() {

        $.get(appUrl('/Home/GetLatestRates'), function (res) {

            rates = res;

            console.log("Rates loaded:", rates);

            if (!rates) return;

            // ? SHOW IN UI
            $("#r24").text((rates.kT_24 || 0).toFixed(2));
            $("#r22").text((rates.oG_22_KT || 0).toFixed(2));
            $("#r21").text((rates.oG_21_KT || 0).toFixed(2));
            $("#r20").text((rates.oG_20_KT || 0).toFixed(2));
            $("#r19").text((rates.oG_19_KT || 0).toFixed(2));
            $("#r18").text((rates.oG_18_KT || 0).toFixed(2));

        }).fail(function () {
            alert("Failed to load rates!");
        });
    }

    function enhanceSearchableSelect(selectSelector) {
        const $select = $(selectSelector);
        if ($select.length === 0) return;

        const enhancedKey = "og_searchselect_enhanced";
        if ($select.data(enhancedKey)) {
            rebuildSearchableSelectOptions($select);
            syncSearchableSelectInput($select);
            return;
        }

        $select.data(enhancedKey, true);

        const ns = `.ogss_${($select.attr("id") || "select")}`;

        const $wrap = $('<div class="og-searchselect"></div>');
        const $input = $('<input type="text" class="form-control og-input" autocomplete="off" placeholder="Search..." />');
        const $dropdown = $('<div class="og-searchselect-dropdown" role="listbox"></div>');

        $select.after($wrap);
        $wrap.append($input, $dropdown);
        $select.hide();

        $select.on("change", function () {
            syncSearchableSelectInput($select);
        });

        $input.on("focus click", function () {
            openSearchableSelect($select);
        });

        $input.on("input", function () {
            filterSearchableSelect($select, $input.val() || "");
        });

        $(document).off("click" + ns).on("click" + ns, function (e) {
            if ($(e.target).closest($wrap).length === 0) {
                closeSearchableSelect($select);
            }
        });

        rebuildSearchableSelectOptions($select);
        syncSearchableSelectInput($select);
    }

    function rebuildSearchableSelectOptions($select) {
        const $wrap = $select.next(".og-searchselect");
        const $dropdown = $wrap.find(".og-searchselect-dropdown");
        $dropdown.empty();

        const options = $select.find("option").map(function () {
            return { value: $(this).attr("value") ?? "", text: $(this).text() ?? "" };
        }).get();

        if (options.length === 0) {
            $dropdown.append('<div class="og-searchselect-muted">No options</div>');
            return;
        }

        for (const opt of options) {
            const safeValue = opt.value ?? "";
            const safeText = opt.text ?? "";

            const $item = $('<div class="og-searchselect-item" role="option"></div>');
            $item.text(safeText);
            $item.attr("data-value", safeValue);

            $item.on("click", function () {
                $select.val(safeValue).trigger("change");
                closeSearchableSelect($select);
            });

            $dropdown.append($item);
        }
    }

    function syncSearchableSelectInput($select) {
        const $wrap = $select.next(".og-searchselect");
        const $input = $wrap.find("input");

        const val = $select.val();
        const text = $select.find("option:selected").text();
        $input.val(val ? text : "");
    }

    function openSearchableSelect($select) {
        const $wrap = $select.next(".og-searchselect");
        const $dropdown = $wrap.find(".og-searchselect-dropdown");
        $dropdown.show();
        filterSearchableSelect($select, $wrap.find("input").val() || "");
    }

    function closeSearchableSelect($select) {
        const $wrap = $select.next(".og-searchselect");
        $wrap.find(".og-searchselect-dropdown").hide();
    }

    function filterSearchableSelect($select, query) {
        const q = (query || "").toString().trim().toLowerCase();
        const $wrap = $select.next(".og-searchselect");
        const $dropdown = $wrap.find(".og-searchselect-dropdown");
        const $items = $dropdown.find(".og-searchselect-item");

        let visibleCount = 0;
        $items.each(function () {
            const text = ($(this).text() || "").toLowerCase();
            const ok = !q || text.includes(q);
            $(this).toggle(ok);
            if (ok) visibleCount++;
        });

        $dropdown.find(".og-searchselect-muted").remove();
        if (visibleCount === 0) {
            $dropdown.append('<div class="og-searchselect-muted">No matches</div>');
        }

        // highlight current selection (if visible)
        const current = ($select.val() ?? "").toString();
        $items.attr("aria-selected", "false").each(function () {
            if (current && ($(this).attr("data-value") ?? "") === current) {
                $(this).attr("aria-selected", "true");
            }
        });
    }
</script>

