@model TestSPA.ViewModel.OGVerificationPrintVM
@{
    Layout = null;
}

@functions {
    public string Fmt(decimal? value) => (value ?? 0).ToString("N2");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OG Verification Sheet - @Model.OGVerifyNo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root { --border: #1f2937; --muted: #6b7280; }
        body { background: #fff; color: #111827; }
        .sheet { max-width: 1100px; margin: 24px auto; padding: 24px; border: 1px solid #e5e7eb; }
        .title { font-weight: 800; letter-spacing: 0.02em; }
        .meta-label { color: var(--muted); font-size: 0.85rem; }
        .meta-value { font-weight: 700; }
        .table th, .table td { vertical-align: middle; }
        .small-note { color: var(--muted); font-size: 0.85rem; }
        .actionbar { display: flex; gap: 8px; justify-content: flex-end; margin-bottom: 12px; }
        @@media print {
            .actionbar { display: none !important; }
            .sheet { border: 0; margin: 0; padding: 0; }
            a[href]:after { content: none !important; }
        }
    </style>
</head>
<body>
    <div class="sheet">
        <div class="actionbar">
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="window.close()">Close</button>
            <button type="button" class="btn btn-sm btn-primary" onclick="window.print()">Print</button>
        </div>

        <div class="row g-3 align-items-end">
            <div class="col-12 col-md-6">
                <div class="title h4 mb-1">OG VERIFICATION SHEET</div>
                <div class="small-note">Generated: @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</div>
            </div>
            <div class="col-12 col-md-6">
                <div class="row g-2">
                    <div class="col-6">
                        <div class="meta-label">OG Verify No</div>
                        <div class="meta-value">@Model.OGVerifyNo</div>
                    </div>
                    <div class="col-6">
                        <div class="meta-label">OG Verified Date</div>
                        <div class="meta-value">@(Model.OGVerifyDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                    </div>
                    <div class="col-6">
                        <div class="meta-label">Receipt No</div>
                        <div class="meta-value">@(Model.ReceiptNo?.ToString() ?? "-")</div>
                    </div>
                </div>
            </div>
        </div>

        <hr class="my-3" />

        <div class="table-responsive">
            <table class="table table-bordered table-sm">
                <thead class="table-light">
                    <tr>
                        <th style="width: 64px;">No.</th>
                        <th>Item Description</th>
                        <th style="width: 120px;">Caratage</th>
                        <th style="width: 120px;" class="text-end">G. Weight</th>
                        <th style="width: 120px;" class="text-end">A. Value</th>
                        <th style="width: 120px;" class="text-end">G. Value</th>
                        <th>Reason</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Details)
                {
                    <tr>
                        <td>@(row.Num ?? 0)</td>
                        <td>@row.ItemDesc</td>
                        <td>@row.Caratage</td>
                        <td class="text-end">@Fmt(row.OGWgt)</td>
                        <td class="text-end">@Fmt(row.OGActVal)</td>
                        <td class="text-end">@Fmt(row.OGGivVal)</td>
                        <td>@row.ReleaseReason</td>
                    </tr>
                }
                </tbody>
                <tfoot>
                    <tr class="table-light">
                        <th colspan="3" class="text-end">Totals</th>
                        <th class="text-end">@Model.TotalWeight.ToString("N2")</th>
                        <th class="text-end">@Model.TotalActValue.ToString("N2")</th>
                        <th class="text-end">@Model.TotalGivValue.ToString("N2")</th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="row g-3 mt-2">
            <div class="col-12">
                <div class="meta-label mb-1">OG Rates</div>
                <table class="table table-bordered table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center">24KT</th>
                            <th class="text-center">22KT</th>
                            <th class="text-center">21KT</th>
                            <th class="text-center">20KT</th>
                            <th class="text-center">19KT</th>
                            <th class="text-center">18KT</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="text-end">@Fmt(Model.KT_24)</td>
                            <td class="text-end">@Fmt(Model.OG_22_KT)</td>
                            <td class="text-end">@Fmt(Model.OG_21_KT)</td>
                            <td class="text-end">@Fmt(Model.OG_20_KT)</td>
                            <td class="text-end">@Fmt(Model.OG_19_KT)</td>
                            <td class="text-end">@Fmt(Model.OG_18_KT)</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="col-12 col-md-4">
                <div class="meta-label">Avg GR</div>
                <div class="meta-value">@Fmt(Model.AvgGoldRate)</div>
            </div>
            <div class="col-12 col-md-8">
                <div class="meta-label">Reason</div>
                <div class="meta-value">@(!string.IsNullOrWhiteSpace(Model.AvgGRReason) ? Model.AvgGRReason : "-")</div>
            </div>
        </div>

        <hr class="my-3" />

        <div class="row g-3">
            <div class="col-12 col-md-4">
                <div class="meta-label">Sales Person</div>
                <div class="meta-value">@(!string.IsNullOrWhiteSpace(Model.SalesPerson) ? Model.SalesPerson : "-")</div>
            </div>
            <div class="col-12 col-md-4">
                <div class="meta-label">Assistant</div>
                <div class="meta-value">@(!string.IsNullOrWhiteSpace(Model.AssSalesPerson) ? Model.AssSalesPerson : "-")</div>
            </div>
            <div class="col-12 col-md-4">
                <div class="meta-label">Price given By</div>
                <div class="meta-value">@(!string.IsNullOrWhiteSpace(Model.PriceGivBy) ? Model.PriceGivBy : "-")</div>
            </div>
        </div>
    </div>

    <script>
        // Auto-open print dialog when the page finishes rendering.
        window.addEventListener('load', () => {
            setTimeout(() => window.print(), 250);
        });
    </script>
</body>
</html>
